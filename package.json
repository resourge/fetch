{
	"name": "@resourge/fetch",
	"description": "This is a set of small packages aiming to simplify the pagination process.",
	"private": false,
	"version": "0.0.0-development",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"javascript",
		"fetch",
		"api",
		"throttle",
		"react",
		"hooks",
		"react-fetch"
	],
	"files": [
		"dist"
	],
	"author": "resourge",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/resourge/fetch.git"
	},
	"scripts": {
		"commit": "git pull && git add . && git-cz",
		"lint": "eslint \"./**/src/**/*.{ts,tsx}\"",
		"lint:prod": "cross-env NODE_ENV=production npm run lint",
		"dev": "vite",
		"build:vite": "vite build",
		"injectBannerIntoDeclarations": "node ./scripts/injectBannerIntoDeclarations.js",
		"fixReactFetch": "node ./scripts/fixReactFetch.js",
		"build": "rollup -c",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"semantic-release": "semantic-release"
	},
	"peerDependencies": {
		"react": ">=17.0.0"
	},
	"dependencies": {
		"@resourge/history-store": "^1.4.0",
		"use-sync-external-store": "^1.6.0"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/preset-env": "^7.29.2",
		"@babel/preset-react": "^7.28.5",
		"@babel/preset-typescript": "^7.28.5",
		"@react-native-community/netinfo": "^12.0.1",
		"@rollup/plugin-babel": "^7.0.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/exec": "^7.1.0",
		"@semantic-release/git": "^10.0.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-native": "^0.73.0",
		"@types/use-sync-external-store": "^1.5.0",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-dev-expression": "^0.2.3",
		"cross-env": "^10.1.0",
		"cz-conventional-changelog": "^3.3.0",
		"eslint-config-resourge": "^1.8.2",
		"fast-glob": "^3.3.3",
		"jsdom": "^29.1.0",
		"minimist": "^1.2.8",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"recursive-copy": "^2.0.14",
		"rollup": "^4.60.2",
		"rollup-plugin-filesize": "^7.0.0",
		"rollup-plugin-shell": "^1.0.9",
		"semantic-release": "^25.0.3",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.10",
		"vite-plugin-checker": "^0.13.0",
		"vitest": "^4.1.5"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
